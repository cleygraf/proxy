<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet source for the Firewall Pro proxy demo.
  %PROXY_URL% is expanded from the environment (NuGet supports env-var expansion),
  so `export PROXY_URL=...` before running dotnet. Default: the docker-wn deployment.

  The local Compose proxy serves plain HTTP. NuGet 6.8+ rejects HTTP sources unless
  allowInsecureConnections is set on that source. The flag only permits an HTTP URL;
  it does not weaken validation when PROXY_URL uses HTTPS.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="firewall-proxy" value="%PROXY_URL%/nuget/v3/index.json"
         protocolVersion="3" allowInsecureConnections="true" />
  </packageSources>
</configuration>
