# Copy this file to .env (which is gitignored) and fill in your own values.
#
# Base URL of the git-pkgs proxy the demo talks to (no trailing slash).
# Examples: http://localhost:8080 (local proxy container) or a hosted proxy URL.
PROXY_URL=http://localhost:8080

# Sonatype Firewall Pro basic-auth credentials.
# Needed ONLY to run verify-firewall-blocking.sh in its default "direct to Firewall" mode;
# the through-proxy demos need no credentials. Replace with your real values in .env.
SONATYPE_FIREWALL_USERNAME=your-firewall-username
SONATYPE_FIREWALL_PASSWORD=your-firewall-password
